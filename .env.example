# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where feedback emails are delivered
FEEDBACK_EMAIL=you@example.com

# Optional: custom sender (defaults to Labmate <onboarding@resend.dev>)
# FEEDBACK_FROM_EMAIL=Labmate <onboarding@resend.dev>

# Public app URL for calendar deep links (defaults to https://labmate.app in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Project URL only — do NOT include /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_…) — either env name works:
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Google Calendar sync (separate from Supabase auth Google login)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Server-only: encrypt stored refresh tokens (generate: openssl rand -base64 32)
CALENDAR_TOKEN_ENCRYPTION_KEY=

# Server-only: for calendar sync API routes
SUPABASE_SERVICE_ROLE_KEY=
